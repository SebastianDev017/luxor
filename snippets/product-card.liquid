{%- comment -%}
  product-card — card reutilizable de producto LUXOR.
  Uso: {% render 'product-card', product: product, num: forloop.index %}
  - product: objeto product (obligatorio)
  - num: entero opcional para la numeración editorial N.0X
{%- endcomment -%}
<style>
  .pcard {
    display: block;
  }
  .pcard-media {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: clip;
    background: var(--bone-deep);
  }
  .pcard-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.001);
    transition: transform 1.3s var(--ease-lux);
  }
  .pcard:hover .pcard-media img {
    transform: scale(1.018);
  }
  .pcard-media svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--stone);
  }
  .pcard-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, color-mix(in srgb, var(--ink) 55%, transparent), transparent 50%);
    opacity: 0;
    transition: opacity 0.6s var(--ease-lux);
  }
  .pcard:hover .pcard-veil,
  .pcard:focus-visible .pcard-veil {
    opacity: 1;
  }
  .pcard-frame {
    position: absolute;
    inset: 0;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    pointer-events: none;
    transition: inset 0.7s var(--ease-lux), border-color 0.7s var(--ease-lux);
  }
  .pcard:hover .pcard-frame,
  .pcard:focus-visible .pcard-frame {
    inset: 10px;
    border-color: color-mix(in srgb, var(--brass-bright) 65%, transparent);
  }
  .pcard-body {
    display: grid;
    gap: 0.3rem;
    padding-top: 1rem;
  }
  .pcard-num {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brass-dark);
  }
  .pcard-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 420;
    line-height: 1.15;
  }
  .pcard-price {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
</style>
{%- liquid
  assign pcard_num = ''
  if num != blank
    assign pcard_num = num | append: '' | prepend: '00' | slice: -2, 2
  endif
  assign pcard_kind = product.type | default: product.vendor
  assign pcard_alt = product.featured_image.alt | default: product.title
-%}
<a class="pcard" href="{{ product.url }}">
  <span class="pcard-media">
    {%- if product.featured_image -%}
      {{ product.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', widths: '360, 540, 720', sizes: '(max-width: 960px) 50vw, 25vw', alt: pcard_alt }}
    {%- else -%}
      {{ 'product-2' | placeholder_svg_tag }}
    {%- endif -%}
    <span class="pcard-veil" aria-hidden="true"></span>
    <span class="pcard-frame" aria-hidden="true"></span>
  </span>
  <span class="pcard-body">
    {%- if pcard_num != '' or pcard_kind != blank -%}
      <span class="pcard-num">
        {%- if pcard_num != '' -%}N.{{ pcard_num }}{%- endif -%}
        {%- if pcard_num != '' and pcard_kind != blank %} · {% endif -%}
        {%- if pcard_kind != blank -%}{{ pcard_kind | escape }}{%- endif -%}
      </span>
    {%- endif -%}
    <span class="pcard-title">{{ product.title | escape }}</span>
    <span class="pcard-price">{{ 'sections.product.from_price' | t }} {{ product.price_min | money }}</span>
  </span>
</a>
