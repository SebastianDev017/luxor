{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ 'gift_cards.issued.title' | t: shop: shop.name, value: gift_card.initial_value | money }}</title>
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/svg+xml" href="{{ 'luxor-favicon.svg' | asset_url }}">
  <style>
    :root {
      --bone: #ede5d6;
      --ink: #191410;
      --umber: #241c14;
      --brass: #a97f45;
      --brass-bright: #c89e63;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Roboto', 'Helvetica Neue', Arial, sans-serif;
      background: var(--ink);
      color: var(--bone);
      min-height: 100vh;
      display: grid;
      place-content: center;
      padding: 2rem;
      text-align: center;
    }
    .card {
      max-width: 26rem;
      border: 1px solid var(--brass);
      padding: 3rem 2.5rem;
      display: grid;
      gap: 1.4rem;
      justify-items: center;
    }
    .card svg { width: 44px; color: var(--brass-bright); }
    h1 { font-weight: 400; font-size: 1.5rem; line-height: 1.3; }
    .value { font-size: 2.6rem; font-weight: 400; color: var(--brass-bright); }
    .code {
      font-family: ui-monospace, monospace;
      font-size: 1.1rem;
      letter-spacing: 0.24em;
      border: 1px dashed var(--brass);
      padding: 0.9rem 1.4rem;
      user-select: all;
    }
    .meta { font-size: 0.85rem; opacity: 0.7; }
    .actions { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-content: center; }
    a.btn, button.btn {
      font-family: ui-monospace, monospace;
      font-size: 0.72rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--brass-bright);
      border: 1px solid var(--brass-bright);
      padding: 0.9rem 1.5rem;
      text-decoration: none;
      cursor: pointer;
    }
    a.btn--ghost { background: transparent; color: var(--bone); border-color: var(--bone); }
    @media print {
      body { background: #fff; color: #000; }
      .actions { display: none; }
    }
  </style>
</head>
<body>
  <main class="card">
    <svg viewBox="0 0 64 88" fill="none" stroke="currentColor" aria-hidden="true">
      <rect x="2" y="2" width="60" height="84" rx="30" stroke-width="1.5"/>
      <path d="M20 26v30h12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M34 40l12 16M46 40L34 56" stroke-width="2" stroke-linecap="round"/>
    </svg>
    <h1>{{ 'gift_cards.issued.subtext' | t }} — {{ shop.name }}</h1>
    <p class="value">{{ gift_card.initial_value | money }}</p>
    {%- if gift_card.enabled == false -%}
      <p class="meta">{{ 'gift_cards.issued.disabled' | t }}</p>
    {%- elsif gift_card.expired -%}
      <p class="meta">{{ 'gift_cards.issued.expired' | t: expiry: gift_card.expires_on | date: '%d/%m/%Y' }}</p>
    {%- elsif gift_card.expires_on -%}
      <p class="meta">{{ 'gift_cards.issued.active' | t: expiry: gift_card.expires_on | date: '%d/%m/%Y' }}</p>
    {%- endif -%}
    <p class="meta">{{ 'gift_cards.issued.redeem' | t }}</p>
    <p class="code">{{ gift_card.code | format_code }}</p>
    <div class="actions">
      <a class="btn" href="{{ shop.url }}">{{ 'gift_cards.issued.shop_link' | t }}</a>
      <a class="btn btn--ghost" href="javascript:window.print()">{{ 'gift_cards.issued.print' | t }}</a>
    </div>
  </main>
</body>
</html>
