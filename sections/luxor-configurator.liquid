{%- liquid
  assign product = section.settings.product
  assign demo = true
  if product != blank
    assign demo = false
  endif
-%}
<section class="config" data-section="config" id="configurador">
  <header class="section-head">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="section-title">{{ section.settings.title_line_1 }}<br><em>{{ section.settings.title_line_2 }}</em></h2>
  </header>
  <div class="config__layout" data-config-root>
    <script type="application/json" data-config-data>
      {
        "demo": {{ demo }},
        "leadDefault": {{ section.settings.lead_default | json }},
        "leadL": {{ section.settings.lead_large | json }},
        "materials": [
          {%- for block in section.blocks -%}
            {
              "name": {{ block.settings.name | json }},
              "tex": {% if block.settings.texture %}{{ block.settings.texture | image_url: width: 1024 | json }}{% else %}{{ 'tex-' | append: block.settings.tex_key | append: '.webp' | asset_url | json }}{% endif %},
              "thumb": {% if block.settings.texture %}{{ block.settings.texture | image_url: width: 256 | json }}{% else %}{{ 'tex-' | append: block.settings.tex_key | append: '-sm.webp' | asset_url | json }}{% endif %}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        ],
        {%- if demo -%}
          {%- assign finish_names = section.settings.demo_finishes | split: ',' -%}
          {%- assign size_names = section.settings.demo_sizes | split: '|' -%}
          "finishes": [{% for f in finish_names %}{ "name": {{ f | strip | json }} }{% unless forloop.last %},{% endunless %}{% endfor %}],
          "sizes": [{% for s in size_names %}{ "name": {{ s | strip | json }} }{% unless forloop.last %},{% endunless %}{% endfor %}],
          "variants": [
            {%- assign fin_factors = '100,112' | split: ',' -%}
            {%- assign size_factors = '100,145,190' | split: ',' -%}
            {%- assign size_letters = 'S,M,L' | split: ',' -%}
            {%- for block in section.blocks -%}
              {%- assign base = block.settings.base_price | times: 100 -%}
              {%- for f in finish_names -%}
                {%- assign fi = forloop.index0 -%}
                {%- assign ff = fin_factors[fi] | plus: 0 -%}
                {%- for s in size_names -%}
                  {%- assign si = forloop.index0 -%}
                  {%- assign sf = size_factors[si] | plus: 0 -%}
                  {%- assign cents = base | times: ff | divided_by: 100 | times: sf | divided_by: 100 -%}
                  {%- assign cents = cents | divided_by: 1000.0 | round | times: 1000 -%}
                  {%- assign mat_abbr = block.settings.name | upcase | remove: 'Á' | remove: 'É' | remove: 'Í' | remove: 'Ó' | remove: 'Ú' | slice: 0, 3 -%}
                  {
                    "id": null,
                    "option1": {{ block.settings.name | json }},
                    "option2": {{ f | strip | json }},
                    "option3": {{ s | strip | json }},
                    "price": {{ cents | money | json }},
                    "sku": "LX-AN01-{{ mat_abbr }}-{{ f | strip | upcase | slice: 0, 3 }}-{{ size_letters[si] }}",
                    "available": true
                  }{% unless forloop.parentloop.parentloop.last and forloop.parentloop.last and forloop.last %},{% endunless %}
                {%- endfor -%}
              {%- endfor -%}
            {%- endfor -%}
          ]
        {%- else -%}
          "finishes": [{% for value in product.options_with_values[1].values %}{ "name": {{ value | json }} }{% unless forloop.last %},{% endunless %}{% endfor %}],
          "sizes": [{% for value in product.options_with_values[2].values %}{ "name": {{ value | json }} }{% unless forloop.last %},{% endunless %}{% endfor %}],
          "variants": [
            {%- for v in product.variants -%}
              {
                "id": {{ v.id }},
                "option1": {{ v.option1 | json }},
                "option2": {{ v.option2 | json }},
                "option3": {{ v.option3 | json }},
                "price": {{ v.price | money | json }},
                "sku": {{ v.sku | default: v.title | json }},
                "available": {{ v.available }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        {%- endif -%}
      }
    </script>

    <div class="config__stage">
      <canvas class="config__canvas" data-config-canvas aria-label="{{ 'sections.configurator.canvas_aria' | t }}"></canvas>
      <p class="config__hint" data-config-hint><span class="config__hint-icon">{% render 'luxor-icon', icon: 'ui-drag' %}</span>{{ 'sections.configurator.drag_hint' | t }}</p>
      <div class="config__ruler" data-config-ruler aria-hidden="true"></div>
      <figure class="config__fallback" data-config-fallback hidden>
        {%- if section.settings.fallback_image -%}
          {{ section.settings.fallback_image | image_url: width: 960 | image_tag: loading: 'lazy', alt: section.settings.fallback_alt }}
        {%- else -%}
          <img src="{{ 'piece-anfora.webp' | asset_url }}" alt="{{ section.settings.fallback_alt }}" loading="lazy" width="640" height="1080">
        {%- endif -%}
      </figure>
    </div>

    <form
      class="config__controls"
      data-config-form
      {% if demo %}action="#configurador"{% else %}method="post" action="{{ routes.cart_add_url }}"{% endif %}
    >
      <fieldset class="config__group" data-group="material">
        <legend class="config__legend">{{ 'sections.configurator.material' | t }}</legend>
        <div class="config__swatches" data-swatches aria-label="{{ 'sections.configurator.material' | t }}"></div>
      </fieldset>
      <fieldset class="config__group" data-group="acabado">
        <legend class="config__legend">{{ 'sections.configurator.finish' | t }}</legend>
        <div class="config__pills" data-finishes aria-label="{{ 'sections.configurator.finish' | t }}"></div>
      </fieldset>
      <fieldset class="config__group" data-group="tamano">
        <legend class="config__legend">{{ 'sections.configurator.size' | t }}</legend>
        <div class="config__sizes" data-sizes aria-label="{{ 'sections.configurator.size' | t }}"></div>
      </fieldset>
      <div class="config__summary" role="status">
        <p class="config__variant"><span class="config__sku" data-sku>—</span><span class="config__lead" data-lead>{{ section.settings.lead_default }}</span></p>
        <p class="config__price" data-price>—</p>
        {%- unless demo -%}
          <input type="hidden" name="id" data-variant-id value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
        {%- endunless -%}
        <button
          class="btn btn--brass config__buy"
          type="submit"
          data-confirm="{{ 'sections.configurator.confirm' | t }}"
          data-soldout="{{ 'sections.configurator.soldout' | t }}"
        >
          {{- section.settings.buy_label -}}
        </button>
        <p class="config__fine">{{ section.settings.fine_print }}</p>
      </div>
    </form>
  </div>
</section>

<script>
  (function () {
    var stage = document.currentScript.previousElementSibling.querySelector('.config__stage')
    var loaded = false
    function load() {
      if (loaded) return
      loaded = true
      var s = document.createElement('script')
      s.src = {{ 'luxor-configurator.js' | asset_url | json }}
      s.defer = true
      document.head.appendChild(s)
    }
    if (!('IntersectionObserver' in window) || (window.Shopify && window.Shopify.designMode)) return load()
    new IntersectionObserver(
      function (entries, io) {
        if (entries[entries.length - 1].isIntersecting) {
          io.disconnect()
          load()
        }
      },
      { rootMargin: '900px' }
    ).observe(stage)
  })()
</script>

{% schema %}
{
  "name": "Configurador 3D",
  "settings": [
    { "type": "product", "id": "product", "label": "Producto", "info": "Producto con 3 opciones en este orden: Material, Acabado, Tamaño. Sin producto, la sección funciona en modo demo con precios calculados." },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "§ 04 · Configurador" },
    { "type": "text", "id": "title_line_1", "label": "Título línea 1", "default": "La Ánfora N.01," },
    { "type": "text", "id": "title_line_2", "label": "Título línea 2 (itálica)", "default": "en tu materia." },
    { "type": "text", "id": "lead_default", "label": "Plazo de entrega", "default": "Entrega en 12 semanas" },
    { "type": "text", "id": "lead_large", "label": "Plazo tamaño grande", "default": "Entrega en 16 semanas" },
    { "type": "text", "id": "buy_label", "label": "Botón de compra", "default": "Encargar esta pieza" },
    { "type": "textarea", "id": "fine_print", "label": "Letra pequeña", "default": "Depósito del 30% al encargar. Cada pieza se numera y firma en el atelier de Barcelona." },
    { "type": "image_picker", "id": "fallback_image", "label": "Imagen de respaldo (sin WebGL)" },
    { "type": "text", "id": "fallback_alt", "label": "Alt del respaldo", "default": "Ánfora N.01 en alabastro, encendida" },
    { "type": "header", "content": "Modo demo (sin producto)" },
    { "type": "text", "id": "demo_finishes", "label": "Acabados (separados por coma)", "default": "Mate,Pulido" },
    { "type": "text", "id": "demo_sizes", "label": "Tamaños (separados por |)", "default": "Sobremesa · 28 cm|Media · 42 cm|Suelo · 60 cm" }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material",
      "settings": [
        { "type": "text", "id": "name", "label": "Nombre (debe coincidir con el valor de la opción Material del producto)", "default": "Travertino" },
        {
          "type": "select",
          "id": "tex_key",
          "label": "Textura LUXOR",
          "options": [
            { "value": "travertino", "label": "Travertino" },
            { "value": "alabastro", "label": "Alabastro" },
            { "value": "laton", "label": "Latón" },
            { "value": "cedro", "label": "Cedro" }
          ],
          "default": "travertino"
        },
        { "type": "image_picker", "id": "texture", "label": "Textura propia (opcional, vertical 1:2)" },
        { "type": "number", "id": "base_price", "label": "Precio base demo (€, tamaño pequeño mate)", "default": 1900 }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Configurador 3D",
      "blocks": [
        { "type": "material", "settings": { "name": "Travertino", "tex_key": "travertino", "base_price": 1900 } },
        { "type": "material", "settings": { "name": "Alabastro", "tex_key": "alabastro", "base_price": 2600 } },
        { "type": "material", "settings": { "name": "Latón", "tex_key": "laton", "base_price": 2400 } },
        { "type": "material", "settings": { "name": "Cedro", "tex_key": "cedro", "base_price": 1400 } }
      ]
    }
  ]
}
{% endschema %}
