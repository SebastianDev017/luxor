<style>
  .reg-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 2rem;
    margin-top: 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .reg-links a {
    color: var(--brass-dark);
    border-bottom: 1px solid color-mix(in srgb, var(--brass-dark) 45%, transparent);
    padding-bottom: 0.2rem;
    transition: border-color 0.3s var(--ease-lux);
  }
  .reg-links a:hover { border-bottom-color: currentColor; }
  .reg-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 1.2rem;
  }
  @media (max-width: 640px) {
    .reg-row { grid-template-columns: 1fr; }
  }
</style>

<div class="page-shell page-shell--narrow">
  <p class="eyebrow">{{ shop.name }} — {{ 'general.brand.byline' | t }}</p>
  {%- assign title_words = 'customer.register.title' | t | split: ' ' -%}
  <h1 class="page-title">
    {%- for word in title_words -%}
      {%- unless forloop.first %} {% endunless -%}
      {%- if forloop.last and forloop.length > 1 -%}<em>{{ word }}</em>{%- else -%}{{ word }}{%- endif -%}
    {%- endfor -%}
  </h1>

  {%- form 'create_customer', novalidate: 'novalidate' -%}
    {%- if form.errors -%}
      <div class="form-status form-status--error" role="alert">{{ form.errors | default_errors }}</div>
    {%- endif -%}
    <div class="reg-row">
      <div class="field">
        <label for="RegisterFirstName">{{ 'customer.register.first_name' | t }}</label>
        <input type="text" id="RegisterFirstName" name="customer[first_name]" autocomplete="given-name">
      </div>
      <div class="field">
        <label for="RegisterLastName">{{ 'customer.register.last_name' | t }}</label>
        <input type="text" id="RegisterLastName" name="customer[last_name]" autocomplete="family-name">
      </div>
    </div>
    <div class="field">
      <label for="RegisterEmail">{{ 'customer.register.email' | t }}</label>
      <input type="email" id="RegisterEmail" name="customer[email]" autocomplete="email" autocapitalize="off" required>
    </div>
    <div class="field">
      <label for="RegisterPassword">{{ 'customer.register.password' | t }}</label>
      <input type="password" id="RegisterPassword" name="customer[password]" autocomplete="new-password" required>
    </div>
    <button class="btn btn--brass" type="submit">{{ 'customer.register.submit' | t }}</button>
  {%- endform -%}

  <div class="reg-links">
    <a href="{{ routes.account_login_url }}">{{ 'customer.log_in' | t }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Clientes — registro",
  "settings": []
}
{% endschema %}
