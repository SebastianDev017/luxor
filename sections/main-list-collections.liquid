<style>
  .lcoll-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(2.5rem, 5vh, 4rem) clamp(1rem, 2.5vw, 2rem);
  }
  .lcoll-card { display: block; }
  .lcoll-card__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: clip;
    background: var(--bone-deep);
  }
  .lcoll-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.001);
    transition: transform 1.3s var(--ease-lux);
  }
  .lcoll-card:hover .lcoll-card__media img { transform: scale(1.018); }
  .lcoll-card__ph {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    color: var(--stone);
    user-select: none;
  }
  .lcoll-card__frame {
    position: absolute;
    inset: 0;
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
    pointer-events: none;
    transition: inset 0.7s var(--ease-lux), border-color 0.7s var(--ease-lux);
  }
  .lcoll-card:hover .lcoll-card__frame,
  .lcoll-card:focus-visible .lcoll-card__frame {
    inset: 10px;
    border-color: color-mix(in srgb, var(--brass-bright) 65%, transparent);
  }
  .lcoll-card__body {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
  }
  .lcoll-card__title {
    font-size: 1.45rem;
    font-weight: 440;
    transition: color 0.3s;
  }
  .lcoll-card:hover .lcoll-card__title { color: var(--brass-dark); }
  .lcoll-card__count {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
  }
  .lcoll-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: clamp(3rem, 8vh, 5rem);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .lcoll-page {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 2.6rem;
    color: var(--text-muted);
    transition: color 0.3s;
  }
  a.lcoll-page:hover { color: var(--brass-dark); }
  @media (max-width: 960px) {
    .lcoll-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .lcoll-grid { grid-template-columns: 1fr; }
  }
</style>

<div class="page-shell">
  <header class="lcoll-head">
    <p class="eyebrow">§ · {{ 'general.brand.byline' | t }}</p>
    {%- assign page_heading = 'sections.list_collections.title' | t | escape -%}
    {%- assign heading_words = page_heading | split: ' ' -%}
    {%- capture heading_html -%}
      {%- for word in heading_words -%}
        {%- if forloop.last and heading_words.size > 1 -%}<em>{{ word }}</em>{%- else -%}{{ word }}{%- endif -%}
        {%- unless forloop.last %} {% endunless -%}
      {%- endfor -%}
    {%- endcapture -%}
    <h1 class="page-title">{{ heading_html }}</h1>
  </header>

  {% paginate collections by section.settings.collections_per_page %}
    <ul class="lcoll-grid" role="list">
      {%- for collection in collections -%}
        <li>
          <a class="lcoll-card" href="{{ collection.url }}">
            <span class="lcoll-card__media">
              {%- if collection.featured_image -%}
                {%- assign img_alt = collection.featured_image.alt | default: collection.title -%}
                {{ collection.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: img_alt, widths: '360, 540, 720, 900', sizes: '(max-width: 560px) 100vw, (max-width: 960px) 50vw, 33vw' }}
              {%- else -%}
                <span class="lcoll-card__ph" aria-hidden="true">{{ collection.title | slice: 0, 1 }}</span>
              {%- endif -%}
              <span class="lcoll-card__frame" aria-hidden="true"></span>
            </span>
            <span class="lcoll-card__body">
              <span class="lcoll-card__title">{{ collection.title }}</span>
              <span class="lcoll-card__count">{{ 'sections.collection_template.products_count' | t: count: collection.products_count }}</span>
            </span>
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- if paginate.pages > 1 -%}
      <nav class="lcoll-pagination" aria-label="{{ 'general.meta.page' | t: page: paginate.current_page }}">
        {%- if paginate.previous -%}
          <a class="lcoll-page" href="{{ paginate.previous.url }}"><span aria-hidden="true">&larr;</span> {{ 'general.pagination.previous' | t }}</a>
        {%- endif -%}
        <span class="lcoll-page">{{ 'general.pagination.page' | t: number: paginate.current_page }}</span>
        {%- if paginate.next -%}
          <a class="lcoll-page" href="{{ paginate.next.url }}">{{ 'general.pagination.next' | t }} <span aria-hidden="true">&rarr;</span></a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {% endpaginate %}
</div>

{% schema %}
{
  "name": "Lista de colecciones",
  "settings": [
    {
      "type": "range",
      "id": "collections_per_page",
      "label": "Colecciones por página",
      "min": 8,
      "max": 24,
      "step": 2,
      "default": 12
    }
  ]
}
{% endschema %}
