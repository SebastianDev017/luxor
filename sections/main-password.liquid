<style>
  .pw-screen {
    position: fixed;
    inset: 0;
    z-index: 150;
    background: var(--ink);
    color: var(--text-inverse);
    display: grid;
    place-items: center;
    padding: var(--gutter);
    overflow-y: auto;
  }
  .pw-inner {
    max-width: 26rem;
    width: 100%;
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 1.4rem;
  }
  .pw-mark { width: 46px; color: var(--brass-bright); }
  .pw-mark svg { display: block; width: 100%; height: auto; }
  .pw-screen .eyebrow {
    color: var(--brass-bright);
    margin-bottom: 0;
  }
  .pw-title {
    font-size: clamp(2.2rem, 1.4rem + 3.5vw, 3.6rem);
  }
  .pw-title em { color: var(--brass-bright); }
  .pw-formhead {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-inverse-muted);
    margin-top: 1rem;
  }
  .pw-form {
    width: 100%;
    max-width: 20rem;
  }
  .pw-form .field { text-align: left; }
  .pw-form .field label { color: var(--text-inverse-muted); }
  .pw-form .field input {
    color: var(--text-inverse);
    border-color: color-mix(in srgb, var(--stone) 35%, transparent);
  }
  .pw-form .field input:focus-visible { outline-color: var(--brass-bright); }
  .pw-screen :focus-visible { outline-color: var(--brass-bright); }
  .pw-form .btn { width: 100%; justify-content: center; }
  .pw-form .form-status { color: var(--brass-bright); border-color: var(--brass-bright); }
  .pw-form .form-status--error { color: #d98a76; border-color: #d98a76; }
  .pw-admin {
    font-size: 0.82rem;
    color: var(--text-inverse-muted);
  }
  .pw-admin a {
    color: var(--brass-bright);
    border-bottom: 1px solid color-mix(in srgb, var(--brass-bright) 45%, transparent);
    padding-bottom: 0.15rem;
  }
</style>

<div class="pw-screen">
  <div class="pw-inner">
    <div class="pw-mark">{% render 'luxor-icon', icon: 'monogram' %}</div>
    <p class="eyebrow eyebrow--center">{{ shop.name }} — {{ 'general.brand.byline' | t }}</p>
    {%- assign title_words = 'general.password_page.opening_soon' | t | split: ' ' -%}
    <h1 class="pw-title">
      {%- for word in title_words -%}
        {%- unless forloop.first %} {% endunless -%}
        {%- if forloop.last and forloop.length > 1 -%}<em>{{ word }}</em>{%- else -%}{{ word }}{%- endif -%}
      {%- endfor -%}
    </h1>
    <h2 class="pw-formhead">{{ 'general.password_page.login_form_heading' | t }}</h2>
    <div class="pw-form">
      {%- form 'storefront_password' -%}
        {%- if form.errors -%}
          <div class="form-status form-status--error" role="alert">{{ form.errors | default_errors }}</div>
        {%- endif -%}
        <div class="field">
          <label for="StorefrontPassword">{{ 'general.password_page.login_form_password_label' | t }}</label>
          <input type="password" id="StorefrontPassword" name="password" autocomplete="current-password" required>
        </div>
        <button class="btn btn--brass" type="submit">{{ 'general.password_page.login_form_submit' | t }}</button>
      {%- endform -%}
    </div>
    <p class="pw-admin">{{ 'general.password_page.admin_link_html' | t }}</p>
  </div>
</div>

{% schema %}
{
  "name": "Página de contraseña",
  "settings": []
}
{% endschema %}
