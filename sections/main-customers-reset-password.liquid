<style>
  .rpw-sub {
    color: var(--text-muted);
    max-width: 28rem;
    margin: -1rem 0 2rem;
  }
</style>

<div class="page-shell page-shell--narrow">
  <p class="eyebrow">{{ shop.name }} — {{ 'general.brand.byline' | t }}</p>
  {%- assign title_words = 'customer.reset_password.title' | t | split: ' ' -%}
  <h1 class="page-title">
    {%- for word in title_words -%}
      {%- unless forloop.first %} {% endunless -%}
      {%- if forloop.last and forloop.length > 1 -%}<em>{{ word }}</em>{%- else -%}{{ word }}{%- endif -%}
    {%- endfor -%}
  </h1>
  <p class="rpw-sub">{{ 'customer.reset_password.subtext' | t }}</p>

  {%- form 'reset_customer_password' -%}
    {%- if form.errors -%}
      <div class="form-status form-status--error" role="alert">{{ form.errors | default_errors }}</div>
    {%- endif -%}
    <div class="field">
      <label for="ResetPassword">{{ 'customer.reset_password.password' | t }}</label>
      <input type="password" id="ResetPassword" name="customer[password]" autocomplete="new-password" required>
    </div>
    <div class="field">
      <label for="ResetPasswordConfirm">{{ 'customer.reset_password.password_confirm' | t }}</label>
      <input type="password" id="ResetPasswordConfirm" name="customer[password_confirmation]" autocomplete="new-password" required>
    </div>
    <button class="btn btn--brass" type="submit">{{ 'customer.reset_password.submit' | t }}</button>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Clientes — restablecer contraseña",
  "settings": []
}
{% endschema %}
