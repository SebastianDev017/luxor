{%- liquid
  assign products_source = section.settings.product_list
  if products_source == blank or products_source.count == 0
    assign products_source = section.settings.collection.products
  endif
  assign limit = section.settings.count
-%}
<section class="pcarousel" data-section="pcarousel">
  <header class="section-head">
    <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    <h2 class="section-title">{{ section.settings.title_line_1 }}{% if section.settings.title_line_2 != blank %}<br><em>{{ section.settings.title_line_2 }}</em>{% endif %}</h2>
  </header>

  <div class="lcarousel" data-carousel>
    <div class="lcarousel__track" data-carousel-track style="--pv: {{ section.settings.per_view }};" tabindex="0" aria-label="{{ section.settings.title_line_1 | strip_html | escape }}">
      {%- if products_source != blank and products_source.count > 0 -%}
        {%- for product in products_source limit: limit -%}
          {% render 'product-card',
            product: product,
            num: forloop.index,
            show_badges: section.settings.show_badges,
            show_variants: section.settings.show_variants,
            show_actions: section.settings.show_actions,
            new_days: section.settings.new_days
          %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          {%- assign ph = i | modulo: 4 | plus: 1 -%}
          <article class="pcard">
            <div class="pcard-media">{{ 'product-' | append: ph | placeholder_svg_tag }}</div>
            <div class="pcard-body">
              <span class="pcard-num">N.0{{ i }}</span>
              <span class="pcard-title">{{ 'onboarding.product_title' | t }}</span>
              <span class="pcard-price">{{ 9900 | money }}</span>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_arrows or section.settings.show_dots -%}
      <div class="lcarousel__nav">
        {%- if section.settings.show_arrows -%}
          <div class="lcarousel__arrows">
            <button class="lcarousel__arrow" type="button" data-carousel-prev aria-label="{{ 'accessibility.previous' | t }}">
              <svg viewBox="0 0 14 14" aria-hidden="true"><path d="M9 2L4 7l5 5" fill="none" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
            <button class="lcarousel__arrow" type="button" data-carousel-next aria-label="{{ 'accessibility.next' | t }}">
              <svg viewBox="0 0 14 14" aria-hidden="true"><path d="M5 2l5 5-5 5" fill="none" stroke="currentColor" stroke-width="1.3"/></svg>
            </button>
          </div>
        {%- endif -%}
        {%- if section.settings.show_dots -%}
          <div class="lcarousel__dots" data-carousel-dots></div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Carrusel de piezas",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "§ Colección · En movimiento" },
    { "type": "text", "id": "title_line_1", "label": "Título línea 1", "default": "La colección," },
    { "type": "text", "id": "title_line_2", "label": "Título línea 2 (itálica)", "default": "en movimiento." },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "product_list", "id": "product_list", "label": "Productos concretos", "info": "Si eliges productos aquí, tienen prioridad sobre la colección." },
    { "type": "range", "id": "count", "label": "Máximo de piezas", "min": 4, "max": 24, "step": 1, "default": 8 },
    { "type": "range", "id": "per_view", "label": "Piezas visibles (escritorio)", "min": 3, "max": 6, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_arrows", "label": "Mostrar flechas", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "Mostrar puntos", "default": true },
    { "type": "header", "content": "Card de producto" },
    { "type": "checkbox", "id": "show_badges", "label": "Mostrar badges (oferta / nuevo / hot)", "default": true },
    { "type": "checkbox", "id": "show_variants", "label": "Mostrar selector de variantes", "default": false },
    { "type": "checkbox", "id": "show_actions", "label": "Mostrar botones de compra", "default": false },
    { "type": "range", "id": "new_days", "label": "Días que una pieza cuenta como «nueva»", "min": 7, "max": 120, "step": 1, "default": 45 }
  ],
  "presets": [
    { "name": "Carrusel de piezas" }
  ]
}
{% endschema %}
